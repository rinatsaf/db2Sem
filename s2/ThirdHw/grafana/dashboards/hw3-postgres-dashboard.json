{
  "id": null,
  "uid": "hw3-postgres-local",
  "title": "HW3 Postgres Monitoring",
  "tags": ["homework", "postgres"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(up{job=\"postgres_exporter\"}, instance)",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PostgreSQL Version",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_server_version_info_value{job=\"postgres_exporter\",instance=~\"$instance\"}",
          "legendFormat": "{{version}}"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "name"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Sessions",
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_stat_activity_count{job=\"postgres_exporter\",state=\"active\",instance=~\"$instance\"})"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "SELECT Rate (rows fetched/sec)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_tup_fetched{job=\"postgres_exporter\",datname!~\"template0|template1\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "INSERT Rate (rows inserted/sec)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_tup_inserted{job=\"postgres_exporter\",datname!~\"template0|template1\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DELETE Rate (rows deleted/sec)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_tup_deleted{job=\"postgres_exporter\",datname!~\"template0|template1\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Average CPU Usage (ms/s)",
      "description": "avg(rate(process_cpu_seconds_total{instance=\"$instance\"}[5m]) * 1000)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "avg(rate(process_cpu_seconds_total{job=\"postgres_exporter\",instance=~\"$instance\"}[5m]) * 1000)"
        }
      ]
    }
  ]
}
